# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Database
DATABASE_URL=postgresql+asyncpg://ledgerflow:ledgerflow@localhost:5432/ledgerflow

# S3 Storage (optional for MVP - falls back to local)
S3_BUCKET=ledgerflow-evidence
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=./storage

# Nova Act
NOVA_ACT_API_KEY=your_nova_act_key

# Mock ERP URL
MOCK_ERP_URL=http://localhost:3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
